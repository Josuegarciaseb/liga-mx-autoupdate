# === Required ===
SPORTAPI_BASE_URL=https://api.tu-sportapi.com/v1
SPORTAPI_KEY=coloca_tu_api_key

# === Optional (defaults shown in workflow) ===
LEAGUE_ID=262          # Liga MX (ajústalo a tu SportAPI)
SEASON=2025            # Año/temporada
FROM_DATE=2025-07-01   # Rango aproximado Apertura
TO_DATE=2025-12-20

# === Adapter config ===
AUTH_HEADER_TYPE=Bearer       # vacío si tu API no usa prefijo (ej. RapidAPI)
AUTH_HEADER_NAME=Authorization  # ej. x-rapidapi-key para RapidAPI

# Header extra (necesario para RapidAPI: x-rapidapi-host)
EXTRA_HEADER_NAME=
EXTRA_HEADER_VALUE=

# === Endpoints (ajusta a tu SportAPI) ===
ENDPOINT_FIXTURES=/fixtures
ENDPOINT_FIXTURE_STATS=/fixtures/statistics
ENDPOINT_TEAMS=/teams
ENDPOINT_STANDINGS=/standings

# === Etiquetas de estadísticas ===
STAT_LABEL_CORNERS=Corner Kicks
STAT_LABEL_YELLOW=Yellow Cards
STAT_LABEL_RED=Red Cards

# ─── Ejemplo para RapidAPI / API-Football ──────────────────────────────────
# SPORTAPI_BASE_URL=https://api-football-v1.p.rapidapi.com/v3
# SPORTAPI_KEY=<tu_key_de_rapidapi>
# AUTH_HEADER_TYPE=
# AUTH_HEADER_NAME=x-rapidapi-key
# EXTRA_HEADER_NAME=x-rapidapi-host
# EXTRA_HEADER_VALUE=api-football-v1.p.rapidapi.com
# ───────────────────────────────────────────────────────────────────────────
